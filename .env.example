# === Бот MAX (max.ru) ===
MAX_BOT_TOKEN=your_max_bot_token_here

# === GigaChat API (Сбер) ===
# Пока не обязателен для запуска текущего MVP
# Base64-строка вида client_id:client_secret
GIGACHAT_CREDENTIALS=your_base64_credentials_here
# GIGACHAT_API_PERS — для физлиц, GIGACHAT_API_CORP — для юрлиц
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель для парсинга запросов
GIGACHAT_PARSE_MODEL=GigaChat-Pro
# Модель для генерации ответов
GIGACHAT_ANSWER_MODEL=GigaChat-Pro

# === Локальное хранилище пилота ===
SQLITE_PATH=data/cases.db
MEDIA_DIR=storage/photos
